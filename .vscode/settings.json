{
  "python.experiments.enabled": false,
  "python.useEnvironmentsExtension": true,
  "[markdown, prompt]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "cSpell.autocorrect": true,
  "cSpell.diagnosticLevel": "Error",
  "cSpell.allowCompoundWords": false,
  "cSpell.customDictionaries": {
    "blog-words": {
      "name": "blog-words",
      "description": "Blog-specific terms",
      "path": "${workspaceFolder}/.cspell/blog-words.txt",
      "addWords": true,
      "scope": "workspace"
    }
  },
  "cSpell.autoFormatConfigFile": false,
  "markdown.copyFiles.destination": {
    "content/**/*.md": "${documentWorkspaceFolder}/content/img/${documentBaseName}__${fileName}"
  }
}
